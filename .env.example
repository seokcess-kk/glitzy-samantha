# NextAuth
# - Production: https://your-domain.com
# - Preview: Vercel이 자동 설정 (VERCEL_URL 사용)
# - Development: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Upstash QStash (https://console.upstash.com/qstash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Vercel Cron 보안키 (환경별로 다른 값 권장)
# 생성: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# Demo 모드 진입 키 (영업 데모/영상 촬영용 — 선택)
# openssl rand -hex 32 로 생성
# 설정 후 scripts/seed-demo-user.ts 실행 필요
# 진입: /demo/enter?key=<여기값>  퇴장: /demo/exit
DEMO_ACCESS_KEY=

# ============================================================
# 광고 API (환경별로 다른 계정 사용 가능)
# ============================================================

# Meta Ads API
META_AD_ACCOUNT_ID=act_xxxxxxxx
META_ACCESS_TOKEN=EAAxxxxxxxx

# Google Ads API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# TikTok Ads API
TIKTOK_ADVERTISER_ID=
TIKTOK_ACCESS_TOKEN=

# TikTok OAuth2 (병원별 연동 시 필수)
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ============================================================
# 외부 서비스 API
# ============================================================

# Kakao 알림톡 (알리고 서비스)
KAKAO_API_KEY=
KAKAO_USER_ID=
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_CODE=
KAKAO_SENDER_NUMBER=

# ============================================================
# Vercel 환경변수 설정 가이드
# ============================================================
# 1. Vercel Dashboard > Settings > Environment Variables
# 2. 각 변수에 대해 환경 선택:
#    - Production: main 브랜치 배포에 사용
#    - Preview: develop/feature 브랜치에 사용
#    - Development: 로컬 개발에 사용 (vercel dev)
# 3. Supabase는 환경별로 별도 프로젝트 생성 권장
# ============================================================
