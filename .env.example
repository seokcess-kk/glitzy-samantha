# Supabase (Supabase 대시보드 > Settings > API에서 확인)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# NextAuth (배포 후 실제 URL로 변경)
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=랜덤-비밀키-여기에-입력

# Admin 로그인 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-password

# Upstash QStash (https://console.upstash.com/qstash)
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Vercel Cron 보안키 (임의 문자열)
CRON_SECRET=your-cron-secret

# Meta Ads API
META_AD_ACCOUNT_ID=act_xxxxxxxx
META_ACCESS_TOKEN=EAAxxxxxxxx

# Google Ads API
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_REFRESH_TOKEN=

# TikTok Ads API
TIKTOK_ADVERTISER_ID=
TIKTOK_ACCESS_TOKEN=

# Kakao 알림톡 (알리고 서비스)
KAKAO_API_KEY=
KAKAO_USER_ID=
KAKAO_SENDER_KEY=
KAKAO_TEMPLATE_CODE=
KAKAO_SENDER_NUMBER=
